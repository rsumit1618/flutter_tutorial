# =============================================
# FASTFILE - Android
# =============================================

default_platform(:android)

platform :android do
  before_all do
    UI.message("🚀 Fastlane for Android")
    UI.message("📱 Project: flutter_tutorial")
    UI.message("🕐 Time: #{Time.now}")
  end

  # =============================================
  # LANE: test - Run all tests
  # =============================================
  desc "Run all tests"
  lane :test do
    UI.message("🧪 Running tests...")

    # First, ensure we have dependencies
    sh 'flutter pub get'

    # Run tests
    sh 'flutter test --coverage'

    UI.success("✅ Tests completed!")
  end

  # =============================================
  # LANE: clean - Clean project
  # =============================================
  desc "Clean project"
  lane :clean do
    UI.message("🧹 Cleaning project...")
    sh 'flutter clean'
    UI.success("✅ Clean completed!")
  end

  # =============================================
  # LANE: build_apk - Build release APK
  # =============================================
  desc "Build release APK"
  lane :build_apk do
    UI.message("🚀 Building APK...")

    # Clean
    sh 'flutter clean'

    # Get dependencies
    sh 'flutter pub get'

    # Build APK
    sh 'flutter build apk --release --split-per-abi'

    if File.exist?('build/app/outputs/flutter-apk/app-release.apk')
      UI.success("✅ APK built successfully!")
      UI.message("📁 Location: build/app/outputs/flutter-apk/")

      # Get file size
      size = File.size('build/app/outputs/flutter-apk/app-release.apk') / (1024 * 1024)
      UI.message("📊 Size: #{size} MB")
    else
      UI.user_error!("❌ APK build failed!")
    end
  end

  # =============================================
  # LANE: build_aab - Build App Bundle
  # =============================================
  desc "Build release App Bundle"
  lane :build_aab do
    UI.message("🚀 Building App Bundle...")

    # Clean
    sh 'flutter clean'

    # Get dependencies
    sh 'flutter pub get'

    # Build AAB
    sh 'flutter build appbundle --release'

    if File.exist?('build/app/outputs/bundle/release/app-release.aab')
      UI.success("✅ App Bundle built successfully!")
      UI.message("📁 Location: build/app/outputs/bundle/release/")

      # Get file size
      size = File.size('build/app/outputs/bundle/release/app-release.aab') / (1024 * 1024)
      UI.message("📊 Size: #{size} MB")
    else
      UI.user_error!("❌ App Bundle build failed!")
    end
  end

  # =============================================
  # LANE: build - Build both APK and AAB
  # =============================================
  desc "Build both APK and AAB"
  lane :build do
    UI.message("🚀 Building both APK and AAB...")

    # Clean
    sh 'flutter clean'

    # Get dependencies
    sh 'flutter pub get'

    # Build APK
    sh 'flutter build apk --release --split-per-abi'

    # Build AAB
    sh 'flutter build appbundle --release'

    if File.exist?('build/app/outputs/flutter-apk/app-release.apk') &&
       File.exist?('build/app/outputs/bundle/release/app-release.aab')
      UI.success("✅ Both builds completed successfully!")
      UI.message("📁 APK: build/app/outputs/flutter-apk/")
      UI.message("📁 AAB: build/app/outputs/bundle/release/")
    else
      UI.user_error!("❌ Build failed!")
    end
  end

  # =============================================
  # LANE: ci - Full CI pipeline
  # =============================================
  desc "Full CI pipeline"
  lane :ci do
    UI.message("🔄 Running CI Pipeline...")
    UI.message("=" * 50)

    # Step 1: Clean
    UI.message("📦 Step 1/6: Cleaning...")
    sh 'flutter clean'

    # Step 2: Get dependencies
    UI.message("📦 Step 2/6: Getting dependencies...")
    sh 'flutter pub get'

    # Step 3: Format
    UI.message("📦 Step 3/6: Formatting...")
    sh 'dart format lib/ test/'

    # Step 4: Analyze
    UI.message("📦 Step 4/6: Analyzing...")
    sh 'flutter analyze'

    # Step 5: Run tests
    UI.message("📦 Step 5/6: Running tests...")
    sh 'flutter test --coverage'

    # Step 6: Build
    UI.message("📦 Step 6/6: Building...")
    sh 'flutter build apk --release --split-per-abi'

    UI.success("=" * 50)
    UI.success("✅ CI Pipeline completed successfully!")
    UI.message("📊 Summary:")
    UI.message("  ✅ Code formatted")
    UI.message("  ✅ Analysis passed")
    UI.message("  ✅ Tests passed")
    UI.message("  ✅ APK built")
  end

  # =============================================
  # LANE: deploy_playstore - Deploy to Play Store
  # =============================================
  desc "Deploy to Play Store Internal Testing"
  lane :deploy_playstore do
    UI.message("🚀 Deploying to Play Store...")

    # Run CI first
    ci

    # Deploy to Play Store
    # Uncomment when you have google-play-key.json
    # upload_to_play_store(
    #   track: 'internal',
    #   release_status: 'completed',
    #   aab: 'build/app/outputs/bundle/release/app-release.aab'
    # )

    UI.message("=" * 50)
    UI.message("⚠️ Play Store upload is currently DISABLED.")
    UI.message("To enable:")
    UI.message("  1. Create service account in Play Console")
    UI.message("  2. Download google-play-key.json")
    UI.message("  3. Place it in android/fastlane/")
    UI.message("  4. Uncomment upload_to_play_store in Fastfile")
    UI.message("=" * 50)

    UI.success("✅ Build ready for Play Store!")
  end

  # =============================================
  # LANE: usage - Show all lanes
  # =============================================
  desc "Show all available lanes"
  lane :usage do
    UI.message("📋 Available Fastlane lanes:")
    UI.message("=" * 40)
    UI.message("  fastlane test             - Run tests")
    UI.message("  fastlane clean            - Clean project")
    UI.message("  fastlane build_apk        - Build APK only")
    UI.message("  fastlane build_aab        - Build AAB only")
    UI.message("  fastlane build            - Build both APK and AAB")
    UI.message("  fastlane ci               - Full CI pipeline")
    UI.message("  fastlane deploy_playstore - Deploy to Play Store")
    UI.message("  fastlane usage            - Show this help message")
    UI.message("=" * 40)
  end

  # =============================================
  # AFTER ALL - Runs after any lane
  # =============================================
  after_all do |lane|
    UI.message("=" * 50)
    UI.success("✅ Lane '#{lane}' completed!")
    UI.message("🕐 Finished at: #{Time.now}")
    UI.message("=" * 50)
  end

  # =============================================
  # ERROR HANDLING
  # =============================================
  error do |lane, exception|
    UI.error("=" * 50)
    UI.error("❌ Error in lane '#{lane}':")
    UI.error("   #{exception.message}")
    UI.error("=" * 50)

    # Show helpful tips
    UI.message("💡 Common fixes:")
    UI.message("  1. Check if Flutter is installed: flutter --version")
    UI.message("  2. Check if all dependencies are installed: flutter pub get")
    UI.message("  3. Check if your code has compilation errors")
  end
end